{
  "name": "qwen3.5-2b-code-128k-forged",
  "version": "1.0.0",
  "description": "2B coding model with 128K context. iPad/cheap laptop target.",
  "author": "continuum-ai",
  "tags": ["code", "128k-context", "yarn", "forge-alloy"],
  "license": "apache-2.0",
  "source": {
    "baseModel": "Qwen/Qwen3.5-2B",
    "architecture": "qwen3_5",
    "isMoE": false
  },
  "stages": [
    {
      "type": "context-extend",
      "targetLength": 131072,
      "method": "yarn"
    },
    {
      "type": "train",
      "domain": "code",
      "dataset": "m-a-p/CodeFeedback-Filtered-Instruction",
      "steps": 2000,
      "learningRate": "2e-4",
      "batchSize": 2,
      "gradientAccumulation": 4,
      "scheduler": "cosine",
      "warmupRatio": 0.03,
      "precision": "bf16",
      "sequenceLength": 4096,
      "optimizations": ["flash_attention", "gradient_checkpointing"]
    },
    {
      "type": "eval",
      "benchmarks": [
        {"name": "humaneval"},
        {"name": "humaneval+"}
      ],
      "compareToBase": true
    },
    {
      "type": "deliver"
    }
  ],
  "cycles": 3,
  "hardware": {
    "minVramGb": 8,
    "recommendedVramGb": 16
  }
}
