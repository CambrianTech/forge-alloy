{
  "name": "qwen3.5-0.8b-code-128k-forged",
  "version": "1.0.0",
  "description": "128K context coding on your phone. 873M params.",
  "author": "continuum-ai",
  "tags": ["code", "128k-context", "yarn", "forge-alloy", "mobile", "edge"],
  "license": "apache-2.0",
  "source": {
    "baseModel": "Qwen/Qwen3.5-0.8B",
    "architecture": "qwen3_5",
    "isMoE": false
  },
  "stages": [
    {
      "type": "context-extend",
      "targetLength": 131072,
      "method": "yarn"
    },
    {
      "type": "train",
      "domain": "code",
      "dataset": "m-a-p/CodeFeedback-Filtered-Instruction",
      "steps": 2000,
      "learningRate": "2e-4",
      "batchSize": 4,
      "gradientAccumulation": 4,
      "scheduler": "cosine",
      "warmupRatio": 0.03,
      "precision": "bf16",
      "sequenceLength": 4096,
      "optimizations": ["flash_attention", "gradient_checkpointing"]
    },
    {
      "type": "eval",
      "benchmarks": [
        {"name": "humaneval"},
        {"name": "humaneval+"}
      ],
      "compareToBase": true
    },
    {
      "type": "deliver"
    }
  ],
  "cycles": 3,
  "hardware": {
    "minVramGb": 4,
    "recommendedVramGb": 8
  }
}
